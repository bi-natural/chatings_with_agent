# vLLM Monitoring All-in-One Docker Image
# CUDA 12.2 devel 이미지 사용 (vLLM 컴파일에 필요)
FROM nvidia/cuda:12.2.0-devel-ubuntu22.04

# 환경 변수 설정
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:$PATH \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH \
    TORCH_CUDA_ARCH_LIST="7.0 7.5 8.0 8.6 8.9 9.0+PTX"

# 기본 패키지 설치 (vLLM 빌드에 필요한 도구 포함)
RUN apt-get update && apt-get install -y \
    python3.10 \
    python3.10-dev \
    python3-pip \
    build-essential \
    git \
    wget \
    curl \
    unzip \
    supervisor \
    nginx \
    ccache \
    && rm -rf /var/lib/apt/lists/*

# Python 패키지 설치
RUN pip3 install --no-cache-dir --upgrade pip setuptools wheel

# vLLM v0.11.0 dependencies
# CUDA 12.2+용 PyTorch 설치 (cu124가 12.2, 12.3, 12.4 모두 호환)
RUN pip3 install --no-cache-dir \
    torch==2.5.1 \
    torchvision==0.20.1 \
    --index-url https://download.pytorch.org/whl/cu124

# vLLM 빌드에 필요한 추가 패키지
RUN pip3 install --no-cache-dir \
    ninja==1.11.1.1 \
    packaging==24.2 \
    wheel==0.45.1

# vLLM v0.11.0 및 관련 패키지
# MAX_JOBS 설정으로 빌드 속도 향상
ENV MAX_JOBS=4
RUN pip3 install --no-cache-dir \
    vllm==0.11.0 \
    transformers==4.49.0 \
    tokenizers==0.21.0 \
    sentencepiece==0.2.0 \
    numpy==2.2.1 \
    requests==2.32.3 \
    tqdm==4.67.1 \
    py-cpuinfo==9.0.0 \
    fastapi==0.115.6 \
    uvicorn[standard]==0.34.0 \
    pydantic==2.10.4 \
    pillow==11.0.0 \
    prometheus-client==0.21.0 \
    aiohttp==3.11.11 \
    openai==1.59.7 \
    psutil==6.1.1 \
    tiktoken==0.8.0 \
    lm-format-enforcer==0.10.9 \
    outlines==0.1.15 \
    typing-extensions==4.12.2 \
    filelock==3.16.1 \
    pyzmq==26.2.0 \
    ray==2.40.0 \
    pandas==2.2.3 \
    msgpack==1.1.0

# Loki 설치
RUN cd /tmp && \
    wget -q https://github.com/grafana/loki/releases/download/v2.9.3/loki-linux-amd64.zip && \
    unzip loki-linux-amd64.zip && \
    mv loki-linux-amd64 /usr/local/bin/loki && \
    chmod +x /usr/local/bin/loki && \
    rm loki-linux-amd64.zip

# Promtail 설치
RUN cd /tmp && \
    wget -q https://github.com/grafana/loki/releases/download/v2.9.3/promtail-linux-amd64.zip && \
    unzip promtail-linux-amd64.zip && \
    mv promtail-linux-amd64 /usr/local/bin/promtail && \
    chmod +x /usr/local/bin/promtail && \
    rm promtail-linux-amd64.zip

# 디렉토리 생성
RUN mkdir -p /var/log/vllm \
    /var/lib/loki/chunks \
    /var/lib/loki/index \
    /var/lib/promtail \
    /etc/loki \
    /etc/promtail \
    /etc/supervisor/conf.d

# Loki 설정 파일 복사
COPY config/loki-config.yml /etc/loki/loki-config.yml

# Promtail 설정 파일 복사
COPY config/promtail-config.yml /etc/promtail/promtail-config.yml

# Nginx 설정 파일 복사
COPY config/nginx.conf /etc/nginx/nginx.conf

# Supervisor 설정 파일 복사
COPY config/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# vLLM 시작 스크립트 복사
COPY scripts/start-vllm.sh /usr/local/bin/start-vllm.sh
RUN chmod +x /usr/local/bin/start-vllm.sh

# 헬스체크 스크립트 복사
COPY scripts/healthcheck.sh /usr/local/bin/healthcheck.sh
RUN chmod +x /usr/local/bin/healthcheck.sh

# 포트 노출
# 8000: 통합 엔드포인트 (vLLM + Loki + Promtail)
#   - /            : vLLM API
#   - /loki        : Loki API (Grafana에서 scrape)
#   - /promtail    : Promtail metrics (선택사항)
EXPOSE 8000

# vLLM 설정을 위한 기본 환경 변수 (override 가능)
ENV MODEL_NAME="" \
    MODEL_PATH="/models" \
    SERVED_MODEL_NAME="" \
    MAX_MODEL_LEN="16384" \
    TENSOR_PARALLEL_SIZE="1" \
    GPU_MEMORY_UTILIZATION="0.9" \
    MAX_NUM_SEQS="256" \
    MAX_NUM_BATCHED_TOKENS="" \
    TRUST_REMOTE_CODE="true" \
    VLLM_EXTRA_ARGS="" \
    LIMIT_MM_PER_PROMPT_IMAGE="0" \
    LIMIT_MM_PER_PROMPT_VIDEO="0"

# 헬스체크
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD /usr/local/bin/healthcheck.sh

# 시작 스크립트 복사
COPY scripts/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Entrypoint로 시작
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
